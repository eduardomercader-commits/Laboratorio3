    stages {
        stage('Primer paso'){
            steps {
                sh 'echo "mensaje desde el terminal"'
            }
        }
        stage('Segundo paso'){
            steps {
                    container('node'){
                        sh 'node --version'
                        sh 'npm --version'
                    }
            }
        }
        stage('Tercer paso'){
            steps {
                container('kubectl'){
                    sh 'kubectl version --client'
                }
            }
        }
    }
}